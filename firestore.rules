rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Is the signed-in user the owner of this document?
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Is the incoming data a valid holding?
    function isValidHolding() {
      let data = request.resource.data;
      return data.keys().hasAll([
        'symbol', 'name', 'type', 'quantity',
        'avgBuyPrice', 'currency', 'source',
        'addedAt', 'updatedAt', 'deletedAt'
      ])
      && data.symbol is string
      && data.quantity is number
      && data.avgBuyPrice is number
      && data.type in ['stock', 'crypto', 'mutual_fund', 'etf']
      && data.currency in ['INR', 'USD']
      && data.source in ['ocr', 'manual', 'import'];
    }

    // ── User documents ──────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can only read and write their own document
      allow read, write: if isOwner(uid);

      // ── Holdings subcollection ────────────────────────────────────────────
      match /holdings/{holdingId} {
        // Read: only the owner
        allow read: if isOwner(uid);

        // Create: owner only, and data must be valid
        allow create: if isOwner(uid) && isValidHolding();

        // Update: owner only
        // (we don't re-validate on update so partial updates work)
        allow update: if isOwner(uid);

        // Delete: not allowed — we use soft deletes (deletedAt field)
        allow delete: if false;
      }

      // ── Watchlist subcollection ───────────────────────────────────────────
      match /watchlist/{itemId} {
        allow read, write: if isOwner(uid);
        allow delete: if false;
      }

      // ── Alerts subcollection ──────────────────────────────────────────────
      // Users can read their own alerts and update (mark as read/dismissed)
      // but cannot create or delete — only server workers create alerts
      match /alerts/{alertId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['readAt', 'dismissed']);
        allow create, delete: if false;
      }

      // ── Daily snapshots ───────────────────────────────────────────────────
      match /snapshots/{date} {
        allow read: if isOwner(uid);
        allow write: if false; // server only
      }
    }

    // ── Shared read-only collections ────────────────────────────────────────
    // Authenticated users can read, but only server workers can write

    match /news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /news_analyses/{newsId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /prices/{symbol} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /prices_history/{symbol}/{rest=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}